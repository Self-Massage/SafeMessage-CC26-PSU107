"""## Threshold Tuning via Precision-Recall Curve
> Konfirmasi bahwa threshold yang dipakai (dari `model_config.json`) memang optimal.
"""

# Threshold Tuning — MAE-focused
precisions_pr, recalls_pr, thresholds_pr = precision_recall_curve(y_test, y_prob)
f1_pr = 2 * precisions_pr[:-1] * recalls_pr[:-1] / (
    precisions_pr[:-1] + recalls_pr[:-1] + 1e-9
)
best_thresh_pr = float(thresholds_pr[np.argmax(f1_pr)])
best_f1_pr     = float(np.max(f1_pr))

# Cari threshold MAE terkecil dengan F1 >= 0.95
thresholds_sw = np.arange(0.1, 0.9, 0.005)
mae_scores_sw = []
f1_scores_sw  = []
acc_scores_sw = []

for t in thresholds_sw:
    y_pred_t = (y_prob >= t).astype(int)
    mae_scores_sw.append(float(np.mean(np.abs(y_test - y_pred_t.astype(float)))))
    f1_scores_sw.append(f1_score(y_test, y_pred_t, zero_division=0))
    acc_scores_sw.append(float(np.mean(y_pred_t == y_test)))

# Cari threshold dengan MAE terkecil (syarat F1 >= 0.95)
best_thresh_sw = None
best_mae_sw    = 999.0

for t, mae_s, f1_s in zip(thresholds_sw, mae_scores_sw, f1_scores_sw):
    if f1_s >= 0.95 and mae_s < best_mae_sw:
        best_mae_sw    = mae_s
        best_thresh_sw = t

# Fallback
if best_thresh_sw is None:
    best_thresh_sw = 0.5
    best_mae_sw    = float(np.mean(np.abs(y_test - (y_prob>=0.5).astype(float))))

best_f1_sw   = f1_score(y_test, (y_prob >= best_thresh_sw).astype(int))
acc_tuned    = float(np.mean((y_prob >= best_thresh_sw).astype(int) == y_test))
y_pred_tuned = (y_prob >= best_thresh_sw).astype(int)

print('='*55)
print('FIX-3: THRESHOLD TUNING (MAE-focused)')
print('='*55)
