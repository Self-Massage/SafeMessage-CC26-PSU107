      f'MAE={float(np.mean(np.abs(y_test-(y_prob>=0.5).astype(float)))):.4f} | '
      f'F1={f1_score(y_test,(y_prob>=0.5).astype(int)):.4f}')
print(f'  Threshold dari config ({THRESHOLD:.3f})    : '
      f'MAE={float(np.mean(np.abs(y_test-y_pred.astype(float)))):.4f} | '
      f'F1={f1:.4f}')
print(f'  Threshold optimal MAE ({best_thresh_sw:.3f})    : '
